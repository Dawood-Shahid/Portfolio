.project-tile {
  width: 500px;
  /* height: 200px; */
  border: 1px solid;
  text-decoration: none;
  color: white;
  font-size: 20px;
  display: flex;
  justify-content: center;
  align-items: center;
}

.project-folder {
  font-size: 25px;
  padding: 0;
  color: black;
  /* border: solid 1px; */
}

.code {
  margin: 0 5px;
  visibility: hidden;
}

.project-title-deco {
  width: 370px;
  /* border: solid 1px red; */
}

.project-tile:hover .code {
  visibility: visible;
  color: black;
  font-size: 20px;
  font-weight: bold;
}

.project-tile:hover .project-folder {
  color: white;
}

#profile-link {
  color: white;
  width: 150px;
  margin: 0 auto;
  text-decoration: none;
  font-size: 20px;
  border: 1px solid;
  padding: 2px 1rem;
  display: flex;
  justify-content: center;
  align-items: center;
}

.forward-icon {
  font-size: 25px;
  margin-left: 1rem;
  color: black;
  /* border: solid 1px; */
}

#profile-link:hover {
  border: 1px solid black;
}

#profile-link:hover .forward-icon {
  color: white;
}

/* contact section */

#contact {
  width: 100%;
  height: 94vh;
  background-image: linear-gradient(45deg, rgb(63, 81, 88) 45%, rgb(5, 56, 77));
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
}

.contact-section-header {
  display: flex;
  flex-direction: column;
  justify-content: center;
  align-items: center;
  margin-bottom: 3rem;
  /* border: 1px solid red; */
}

.contact-section-header > p {
  color: rgb(4, 40, 56);
}

.contact-links {
  width: 600px;
  height: 80px;
  margin: 0 auto;
  display: flex;
  flex-direction: row;
  justify-content: space-around;
  align-items: center;
  /* border: 1px solid; */
}

.contact-details {
  display: flex;
  flex-direction: row;
  justify-content: center;
  align-items: center;
}

.contact-details > i {
  display: inline-block;
  width: 25px;
  /* border: 1px solid; */
}

.contact-details > span {
  display: inline-block;
  width: 130px;
  /* border: 1px solid; */
  text-align: center;
}

.contact-links > a {
  color: black;
  text-decoration: none;
  font-size: 20px;
  /* margin: 0 2px 0 2px; */
  /* border: 1px solid black; */
  padding: 2px 1rem;
}

.contact-links > a:hover {
  border: 1px solid black;
  padding: 2px 15px;
  color: white;
}

footer > p {
  border-top: 1px dotted white;
  border-bottom: 1px dotted white;
  font-size: 16px;
  text-align: center;
  color: white;
  background-color: rgb(4, 45, 63);
}

html {
  scroll-behavior: smooth;
}
